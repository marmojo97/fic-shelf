{
  "manifest_version": 3,
  "name": "Archivd – Fic Tracker",
  "version": "1.0.0",
  "description": "Save fanfics from AO3 and FFN to your Archivd shelf with one click.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://archiveofourown.org/*",
    "https://www.fanfiction.net/*",
    "https://fanfiction.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://archiveofourown.org/works/*",
        "https://www.fanfiction.net/s/*",
        "https://fanfiction.net/s/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "settings.html"
}
